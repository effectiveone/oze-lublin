---
import Layout from './Layout.astro';
const { frontmatter } = Astro.props;
const dateStr = new Date(frontmatter.pubDate).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Layout title={frontmatter.title} description={frontmatter.description}>
  <div class="container" style="padding:2.5rem 1.5rem 4rem;max-width:860px;">
    <header style="margin-bottom:2.5rem;">
      {frontmatter.tags?.map((t: string) => <span style="display:inline-block;background:var(--terra-pale);color:var(--terra-dark);font-size:0.7rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:3px;margin-right:0.4rem;text-transform:uppercase;">{t}</span>)}
      <h1 style="font-family:'Lora',serif;font-size:clamp(1.7rem,4vw,2.6rem);margin:0.75rem 0 0.5rem;line-height:1.2;">{frontmatter.title}</h1>
      <p style="color:var(--text-muted);font-size:0.88rem;margin-bottom:0.75rem;">🌻 {dateStr} · {frontmatter.author}</p>
      <p style="font-size:1.05rem;color:var(--terra);font-style:italic;border-left:4px solid var(--terra);padding-left:1rem;">{frontmatter.description}</p>
    </header>
    <div class="lora-prose"><slot /></div>
  </div>
</Layout>
<style>
.lora-prose :global(h2) { font-family:'Lora',serif;color:var(--terra-dark);font-size:1.45rem;margin:2rem 0 0.75rem;border-bottom:2px solid var(--terra-pale);padding-bottom:0.5rem; }
.lora-prose :global(p) { margin-bottom:1.3rem;line-height:1.8; }
.lora-prose :global(a) { color:var(--terra);border-bottom:1px solid var(--terra-pale); }
</style>
