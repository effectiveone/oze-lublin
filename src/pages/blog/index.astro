---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="Artykuły — OZE Lublin">
  <div class="container" style="padding:2.5rem 1.5rem 3rem;">
    <h1 style="font-family:'Lora',serif;color:var(--text);font-size:2.2rem;border-bottom:2px solid var(--terra-pale);padding-bottom:0.75rem;margin-bottom:0.75rem;">Artykuły</h1>
    <p style="color:var(--text-muted);margin-bottom:2rem;">{posts.length} artykułów o OZE na Lubelszczyźnie</p>
    {posts.length > 0 ? (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.25rem;">
        {posts.map(p => <PostCard title={p.data.title} description={p.data.description} slug={p.slug} pubDate={p.data.pubDate} tags={p.data.tags} />)}
      </div>
    ) : <p style="text-align:center;color:var(--text-muted);padding:3rem 0;">Artykuły pojawią się wkrótce.</p>}
  </div>
</Layout>
