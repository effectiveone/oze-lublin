---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="OZE Lublin — Energia odnawialna na Lubelszczyźnie">
  <div style="background:linear-gradient(135deg,var(--terra-pale),#fff);padding:3.5rem 0 3rem;border-bottom:3px solid var(--terra-pale);">
    <div class="container">
      <h1 style="font-family:'Lora',serif;font-size:clamp(2rem,5vw,3rem);color:var(--text);margin-bottom:1rem;">Energia odnawialna<br/><span style="color:var(--terra);">na Lubelszczyźnie</span></h1>
      <p style="font-size:1.1rem;color:var(--text-muted);max-width:560px;margin-bottom:1.5rem;">Lokalny portal o fotowoltaice, biomasie, geotermii i zielonych inicjatywach w Lublinie i regionie lubelskim.</p>
      <a href="/blog" style="background:var(--terra);color:#fff;padding:0.65rem 1.5rem;font-weight:700;border-radius:5px;display:inline-block;">Przeglądaj artykuły</a>
    </div>
  </div>
  <div class="container" style="padding:2.5rem 1.5rem 3rem;">
    {posts.length > 0 ? (
      <>
        <h2 style="font-family:'Lora',serif;font-size:1.5rem;color:var(--text);margin-bottom:1.5rem;border-left:4px solid var(--terra);padding-left:0.75rem;">Najnowsze artykuły</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.25rem;margin-bottom:2rem;">
          {posts.slice(0,6).map(p => <PostCard title={p.data.title} description={p.data.description} slug={p.slug} pubDate={p.data.pubDate} tags={p.data.tags} />)}
        </div>
        {posts.length > 6 && <div style="text-align:center;"><a href="/blog" style="color:var(--terra);font-weight:700;border-bottom:2px solid var(--terra);padding-bottom:2px;">Wszystkie artykuły ({posts.length}) →</a></div>}
      </>
    ) : (
      <div style="text-align:center;padding:4rem 0;">
        <span style="font-size:3rem;">🌻</span>
        <h2 style="font-family:'Lora',serif;color:var(--terra);margin-top:0.75rem;">Artykuły wkrótce</h2>
        <p style="color:var(--text-muted);margin-top:0.5rem;">Przygotowujemy treści o OZE w Lublinie.</p>
      </div>
    )}
  </div>
</Layout>
