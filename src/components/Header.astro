<header class="warm-header">
  <div class="container warm-inner">
    <a href="/" class="warm-logo">
      <span style="font-size:1.8rem;">🌻</span>
      <div>
        <span class="warm-logo-name">OZE Lublin</span>
        <span class="warm-logo-sub">Lubelska energia odnawialna</span>
      </div>
    </a>
    <nav class="warm-nav">
      <a href="/">Strona główna</a>
      <a href="/blog">Artykuły</a>
      <a href="https://ecoaudyt.app" target="_blank" rel="noopener" class="warm-cta">Audyt energetyczny</a>
    </nav>
  </div>
</header>

<style>
.warm-header { background: var(--terra); }
.warm-inner { display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.5rem; }
.warm-logo { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
.warm-logo-name { display: block; font-family: 'Lora', serif; font-weight: 700; font-size: 1.25rem; color: #fff; }
.warm-logo-sub { display: block; font-size: 0.68rem; color: rgba(255,255,255,0.75); letter-spacing: 0.04em; }
.warm-nav { display: flex; gap: 1.25rem; align-items: center; }
.warm-nav a { color: rgba(255,255,255,0.9); font-size: 0.9rem; font-weight: 400; text-decoration: none; }
.warm-nav a:hover { color: #fff; text-decoration: none; }
.warm-cta { background: rgba(255,255,255,0.15) !important; border: 1px solid rgba(255,255,255,0.4); color: #fff !important; padding: 0.35rem 0.9rem; border-radius: 4px; font-weight: 700 !important; }
.warm-cta:hover { background: rgba(255,255,255,0.25) !important; }
</style>
